# NutriMind OS — Environment Variables
# Copy this file to .env and fill in your values

# ─── Required ────────────────────────────────────────────────────────────────

# JWT secret — use any long random string (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=change_this_to_a_long_random_secret

# Groq API key — get free at https://console.groq.com (no credit card needed)
# Sign up → API Keys → Create API Key
GROQ_API_KEY=gsk_your_groq_api_key_here

# ─── Optional ────────────────────────────────────────────────────────────────

# Backend port (defaults to 3001)
PORT=3001

# Frontend URL — used in email links (defaults to http://localhost:5175)
CLIENT_URL=http://localhost:5173

# Set to 'production' when deploying (enables static file serving + open CORS)
# NODE_ENV=production

# Gmail credentials for email features (optional — app works without these)
# EMAIL_USER=your_gmail@gmail.com
# EMAIL_PASS=your_gmail_app_password  # Get at: myaccount.google.com → Security → App Passwords
